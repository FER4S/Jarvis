# Secrets — never commit
.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Logs
logs/
*.log

# faster-whisper model cache
models/whisper/

# openwakeword model cache
models/openwakeword/

# Jarvis persistent memory store (local, per-machine, personal data)
data/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
